{
  "name": "forge-loop",
  "version": "0.1.0",
  "description": "Claude Code agent that auto-improves your OSS every N hours via domain rotation, materialized stages, and a defer lane.",
  "author": "killertcell428",
  "license": "MIT",
  "repository": "https://github.com/killertcell428/forge-loop",
  "keywords": ["auto-improvement", "self-improvement", "agent", "loop", "oss"],
  "skills": [
    "skills/forge-research.md",
    "skills/forge-plan.md",
    "skills/forge-implement.md",
    "skills/forge-test.md",
    "skills/forge-release.md"
  ],
  "agents": [
    "agents/forge-orchestrator.md"
  ],
  "entrypoint": "agents/forge-orchestrator.md",
  "config": {
    "rotation_file": "auto-improvement/ROTATION.md",
    "domains_file": "auto-improvement/domains.yaml",
    "index_file": "auto-improvement/INDEX.md",
    "research_dir": "auto-improvement/research/",
    "changes_dir": "auto-improvement/changes/",
    "pending_dir": "auto-improvement/pending/",
    "defer_thresholds": {
      "max_loc_per_change": 100,
      "block_api_breaking": true
    },
    "release_threshold": {
      "min_accumulated_units": 3
    }
  }
}
